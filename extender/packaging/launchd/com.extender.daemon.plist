<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.extender.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/extender</string>
        <string>daemon</string>
    </array>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/extender.log</string>

    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/extender.log</string>

    <key>WorkingDirectory</key>
    <string>/usr/local/var/extender</string>
</dict>
</plist>
